---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = [
  { id: 'agriculteurs', title: t('audience.1.title'), body: t('audience.1.body') },
  { id: 'cooperatives', title: t('audience.2.title'), body: t('audience.2.body') },
  { id: 'bureaux-etudes', title: t('audience.3.title'), body: t('audience.3.body') },
];
---
{items.map((item, i) => (
  <section id={item.id} class:list={['scroll-mt-20 px-6 py-16 sm:py-20', i % 2 === 1 && 'bg-slate-50']}>
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-primary-blue">{item.title}</h2>
      <p class="mt-4 text-slate-600 text-base sm:text-lg">{item.body}</p>
    </div>
  </section>
))}
