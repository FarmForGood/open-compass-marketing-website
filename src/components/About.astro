---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="about" class="max-w-5xl mx-auto px-6 py-16 sm:py-20 grid sm:grid-cols-2 gap-12 items-center">
  <img
    src="/images/about.svg"
    alt=""
    class="w-full h-auto rounded-2xl"
    width="600"
    height="450"
  />
  <div>
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">{t('about.title')}</h2>
    <p class="mt-4 text-slate-600 text-base sm:text-lg">{t('about.body')}</p>
  </div>
</section>
