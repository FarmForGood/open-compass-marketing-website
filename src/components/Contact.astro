---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const email = 'contact@opencompass.org';
---
<section id="contact" class="max-w-3xl mx-auto px-6 py-16 sm:py-24 text-center">
  <p class="mt-4 text-slate-600 text-base sm:text-lg mb-2">
    <a href={`/docs/methodo_${lang}.pdf`} download class="underline hover:text-slate-900">{t('contact.questions')}</a>
  </p>
  <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">{t('contact.title')}</h2>
  <p class="mt-4 text-slate-600 text-base sm:text-lg">{t('contact.body')}</p>
  <p class="mt-6 text-sm text-slate-500">{t('contact.email.label')}</p>
  <a href={`mailto:${email}`} class="text-lg font-medium text-slate-900 hover:underline">{email}</a>
</section>
