---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = [
  { icon: '/images/icon-brand.svg', title: t('features.1.title'), body: t('features.1.body') },
  { icon: '/images/icon-web.svg', title: t('features.2.title'), body: t('features.2.body') },
  { icon: '/images/icon-growth.svg', title: t('features.3.title'), body: t('features.3.body') },
];
---
<section id="features" class="bg-slate-50 py-16 sm:py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-center">{t('features.title')}</h2>
    <div class="mt-12 grid sm:grid-cols-3 gap-8">
      {items.map((item) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
          <img src={item.icon} alt="" class="w-10 h-10" width="40" height="40" />
          <h3 class="mt-4 font-semibold text-lg">{item.title}</h3>
          <p class="mt-2 text-slate-600 text-sm">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
