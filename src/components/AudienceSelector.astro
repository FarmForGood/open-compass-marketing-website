---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = [
  { label: t('audience.1.label'), href: '#agriculteurs', image: '/images/agri.png', w: 147, h: 102, imageClass: 'max-h-full' },
  { label: t('audience.2.label'), href: '#cooperatives', image: '/images/indus.png', w: 236, h: 236, imageClass: 'max-h-full' },
  { label: t('audience.3.label'), href: '#bureaux-etudes', image: '/images/consultant.webp', w: 200, h: 200, imageClass: 'max-h-20' },
];
---
<section id="audience" class="scroll-mt-20 max-w-5xl mx-auto px-6 py-16 sm:py-20">
  <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-center text-primary-blue">{t('audience.title')}</h2>
  <div class="mt-12 grid sm:grid-cols-3 gap-6">
    {items.map((item) => (
      <a
        href={item.href}
        class="block bg-white rounded-2xl p-6 shadow-sm border border-slate-100 hover:border-primary-green hover:shadow-md transition-all text-center font-medium text-primary-blue"
      >
        {item.label}
        <div class="mt-4 h-28 flex items-center justify-center">
          <img src={item.image} alt="" width={item.w} height={item.h} class:list={[item.imageClass, 'w-auto']} />
        </div>
      </a>
    ))}
  </div>
</section>
