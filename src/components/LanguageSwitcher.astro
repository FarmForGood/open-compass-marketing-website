---
import { languages, type Lang, getLocalizedPath } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const codes = Object.keys(languages) as Lang[];
---
<div class="flex items-center gap-2 text-sm">
  {codes.map((code, i) => (
    <>
      {i > 0 && <span class="text-slate-300">/</span>}
      {code === lang ? (
        <span class="font-semibold text-primary-blue">{code.toUpperCase()}</span>
      ) : (
        <a href={getLocalizedPath(currentPath, code)} class="text-slate-500 hover:text-primary-blue">
          {code.toUpperCase()}
        </a>
      )}
    </>
  ))}
</div>
