---
import { Smartphone, BarChart3, FileText, ArrowRight } from 'lucide-astro';
import { useTranslations, boldify, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const steps = [
  { icon: Smartphone, text: t('process.1.text') },
  { icon: BarChart3, text: t('process.2.text') },
  { icon: FileText, text: t('process.3.text') },
];
---
<section class="bg-primary-bg">
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-20 sm:pt-24 sm:pb-28 flex flex-col items-center text-center">
    <h1 class="text-3xl sm:text-5xl font-bold tracking-tight leading-tight text-primary-blue">{t('hero.title')}</h1>
    <p class="mt-5 text-slate-600 text-base sm:text-lg max-w-xl">{t('hero.subtitle')}</p>
    <div class="mt-10 w-full bg-white rounded-2xl border border-slate-200 shadow-sm px-6 py-8 sm:px-10 sm:py-10">
      <div class="flex items-start justify-center gap-3 sm:gap-6 text-primary-blue">
        {steps.map((step, i) => (
          <>
            {i > 0 && (
              <div class="h-14 sm:h-20 flex items-center">
                <ArrowRight class="h-5 w-5 sm:h-6 sm:w-6 text-slate-300 shrink-0" />
              </div>
            )}
            <div class="flex flex-col items-center gap-3 w-28 sm:w-40">
              <div class="h-14 w-14 sm:h-20 sm:w-20 rounded-full bg-primary-bg flex items-center justify-center">
                <step.icon class="h-7 w-7 sm:h-9 sm:w-9" stroke-width={1.75} />
              </div>
              <p class="text-xs sm:text-sm text-slate-600" set:html={boldify(step.text)} />
            </div>
          </>
        ))}
      </div>
    </div>
    <a
      href={`/${lang}#contact`}
      class="inline-block mt-8 bg-primary-blue text-white px-6 py-3 rounded-md text-sm font-medium hover:bg-primary-blue/90 transition-colors"
    >
      {t('hero.cta')}
    </a>
  </div>
</section>
